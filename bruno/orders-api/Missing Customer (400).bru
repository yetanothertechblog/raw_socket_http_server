meta {
  name: Missing Customer (400)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/orders
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "item": "widget",
    "quantity": 1,
    "price_cents": 100
  }
}

settings {
  sslVerification: false
}

assert {
  res.status: eq 400
}
